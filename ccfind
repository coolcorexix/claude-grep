#!/usr/bin/env python3
"""ccfind - interactive content search across your agent conversation histories.

Searches Claude Code, OpenCode, and Hermes from one UI. Type a phrase; jump back
into any past session with a single keypress. Each row is tagged with the agent
it came from ([c] Claude / [h] Hermes / [o] OpenCode).

Usage:
  ccfind                      launch interactive search across all detected agents
  ccfind --source claude,hermes
                              limit to specific agents (comma-separated)
  ccfind --user-only | -u     match only text YOU typed, not AI responses or
                              tool output (toggle inside the UI with Ctrl-U)
  ccfind --sources            list which agents are detected on this machine
  ccfind --backend Q          (internal) emit matching rows for query Q
  ccfind --preview F Q        (internal) render the preview pane
"""
import glob
import json
import os
import re
import shlex
import sqlite3
import subprocess
import sys
import uuid as _uuid_mod
from datetime import datetime

# Make the sibling ccfind_core package importable in both dev (script run
# from repo) and Nix installs (script lives in $out/bin, package lives in
# $out/share/ccfind). Imports of ccfind_core happen lazily inside the
# handlers that need them so users on older installs still get the search
# UI even if the package is missing.
# realpath (not abspath) so a symlinked launcher (e.g. ~/.local/bin/ccfind ->
# repo/ccfind) resolves to the real file's dir and still finds ccfind_core.
_HERE = os.path.dirname(os.path.realpath(__file__))
for _candidate in (_HERE, os.path.join(os.path.dirname(_HERE), "share", "ccfind")):
    if os.path.isdir(os.path.join(_candidate, "ccfind_core")) and _candidate not in sys.path:
        sys.path.insert(0, _candidate)

HOME = os.path.expanduser("~")
MAX_FILES = 150
MAX_RESULTS = 80
CTX_BEFORE = 60
CTX_AFTER = 140

YELLOW = "\x1b[1;33m"
DIM = "\x1b[2m"
BOLD = "\x1b[1m"
CYAN = "\x1b[36m"
RESET = "\x1b[0m"

# Source badges (256-color, distinct per agent)
BADGES = {
    "claude":   "\x1b[38;5;87m[c]\x1b[0m",
    "hermes":   "\x1b[38;5;213m[h]\x1b[0m",
    "opencode": "\x1b[38;5;215m[o]\x1b[0m",
}

# fzf prompts double as the mode flag: backend/preview subprocesses spawned by
# fzf read FZF_PROMPT from the environment to know whether the user-only
# filter is active (fzf exports it to reload/preview commands).
PROMPT_ALL = "search> "
PROMPT_USER = "user> "

# Default config dir, kept for back-compat. Real discovery goes through
# claude_roots(), which also finds per-account config dirs (see below).
CLAUDE_ROOT = os.path.join(HOME, ".claude", "projects")
HERMES_ROOT = os.path.join(HOME, ".hermes")
OPENCODE_DB = os.path.join(HOME, ".local", "share", "opencode", "opencode.db")

ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")
_WIDTH = None


def _vlen(s):
    return len(ANSI_RE.sub("", s))


def _vtrunc(s, n):
    out, count, i = [], 0, 0
    while i < len(s) and count < n:
        m = ANSI_RE.match(s, i)
        if m:
            out.append(m.group(0))
            i = m.end()
            continue
        out.append(s[i])
        count += 1
        i += 1
    return "".join(out)


def _term_width():
    global _WIDTH
    if _WIDTH is not None:
        return _WIDTH
    w = 0
    try:
        import fcntl
        import struct
        import termios
        with open("/dev/tty") as tty:
            _, w, _, _ = struct.unpack(
                "HHHH", fcntl.ioctl(tty, termios.TIOCGWINSZ, b"\0" * 8))
    except Exception:
        w = 0
    if not w:
        try:
            w = int(os.environ.get("COLUMNS", 0))
        except ValueError:
            w = 0
    _WIDTH = w or 100
    return _WIDTH


def fmt_ts(ts):
    if ts is None or ts == "":
        return ""
    try:
        if isinstance(ts, (int, float)):
            t = ts / 1000.0 if ts > 1e12 else float(ts)
            dt = datetime.fromtimestamp(t).astimezone()
        else:
            dt = datetime.fromisoformat(str(ts).replace("Z", "+00:00")).astimezone()
        return dt.strftime("%y-%m-%d %H:%M")
    except Exception:
        return str(ts)[:16].replace("T", " ")


def ts_key(ts):
    """Float epoch for sorting; 0 if unparseable."""
    if ts is None or ts == "":
        return 0.0
    if isinstance(ts, (int, float)):
        return ts / 1000.0 if ts > 1e12 else float(ts)
    try:
        return datetime.fromisoformat(str(ts).replace("Z", "+00:00")).timestamp()
    except Exception:
        return 0.0


def abbrev(path):
    if path and path.startswith(HOME):
        return "~" + path[len(HOME):]
    return path or "?"


def _sep_pattern(q):
    """Match the alphanumeric run of q with at most one non-alnum char between
    each pair. Any non-alnum char IN q (space, slash, punctuation) becomes a
    flexible separator slot — so 'crash loop' matches 'crash loop' /
    'crash-loop' / 'crashloop', and 'rSideProject' matches 'r/SideProject'.

    Emitting only alnum literals also keeps the pattern valid for ripgrep:
    Python's re.escape(' ') is '\\ ', which Rust's regex engine rejects, so the
    old per-char version made every multi-word query silently return nothing."""
    chars = [c for c in q if c.isalnum()]
    if not chars:
        return r"\b\B"  # never matches (degenerate all-symbol query)
    return "[^a-zA-Z0-9]?".join(re.escape(c) for c in chars)


def highlight(text, q):
    if not q:
        return text
    return re.sub(_sep_pattern(q),
                  lambda m: YELLOW + m.group(0) + RESET,
                  text, flags=re.IGNORECASE)


def align_right(left, right):
    if not right:
        return left
    usable = max(24, _term_width() - 3)
    gap = usable - _vlen(left) - len(right)
    if gap < 1:
        left = _vtrunc(left, max(0, usable - len(right) - 2)) + "…" + RESET
        gap = 1
    return left + " " * gap + DIM + right + RESET


def snippet_around(text, q, idx):
    qlen = len(q)
    s = max(0, idx - CTX_BEFORE)
    e = min(len(text), idx + qlen + CTX_AFTER)
    out = text[s:e]
    if s > 0:
        out = "…" + out
    if e < len(text):
        out = out + "…"
    return re.sub(r"\s+", " ", out).strip()


def first_text_match(text, q):
    if not text or not q:
        return None
    m = re.search(_sep_pattern(q), text, re.IGNORECASE)
    if not m:
        return None
    return snippet_around(text, q, m.start())


def first_text(text, limit=CTX_BEFORE + CTX_AFTER):
    """Snippet for the no-query 'recent conversations' listing: just the
    start of the text, no match to center on."""
    if not text:
        return None
    s = re.sub(r"\s+", " ", text).strip()
    if not s:
        return None
    return s if len(s) <= limit else s[:limit] + "…"


def raw_snippet(raw, q):
    m = re.search(_sep_pattern(q), raw, re.IGNORECASE)
    if not m:
        return None
    i = m.start()
    seg = raw[max(0, i - 80): i + len(q) + 160]
    seg = (seg.replace("\\n", " ").replace("\\t", " ")
              .replace('\\"', '"').replace("\\\\", "\\"))
    return re.sub(r"\s+", " ", seg).strip()


# =====================
# CLAUDE adapter
# =====================
def claude_roots():
    """Every Claude Code `projects` dir to search.

    Claude stores transcripts under its config dir (default ~/.claude). People
    who run several accounts on one machine give each login its own config dir
    via CLAUDE_CONFIG_DIR — typically ~/.claude, ~/.claude-work,
    ~/.claude-personal, etc. Only one is ever 'active', so `claude --resume`
    alone can't see the others. ccfind searches them ALL so a conversation is
    findable (and resumable) no matter which account is currently selected.

    Order: the active CLAUDE_CONFIG_DIR first, then the default ~/.claude, then
    any sibling ~/.claude-* dirs. Duplicates (by realpath) are dropped."""
    roots, seen = [], set()

    def add(base):
        if not base:
            return
        p = os.path.join(base, "projects")
        rp = os.path.realpath(p)
        if rp in seen or not os.path.isdir(p):
            return
        seen.add(rp)
        roots.append(p)

    add(os.environ.get("CLAUDE_CONFIG_DIR"))
    add(os.path.join(HOME, ".claude"))
    for d in sorted(glob.glob(os.path.join(HOME, ".claude-*"))):
        add(d)
    return roots


def _claude_config_dir_for_path(path):
    """Given a transcript path, return the config dir that owns it (the parent
    of its `projects` dir) so we can point `claude --resume` at the right
    account. Returns None if the path isn't under a recognizable layout."""
    d = os.path.dirname(os.path.abspath(path))
    while d and d != os.path.dirname(d):
        if os.path.basename(d) == "projects":
            return os.path.dirname(d)
        d = os.path.dirname(d)
    return None


def claude_available():
    return bool(claude_roots())


def _claude_live_path_uuids(path):
    """The set of message uuids on the path Claude reconstructs when it resumes
    this transcript — the lineage of the *newest tip* (the last appended
    uuid-bearing line).

    A Claude session is a tree, not a line: editing/re-sending a message (or two
    terminals on one session) forks the `parentUuid` chain. `claude --resume`
    only ever opens the newest tip, so messages NOT in this set live on
    abandoned branches and are invisible after resume. Walks parentUuid over ALL
    node types (system / compaction entries sit on the spine too)."""
    parent = {}
    last_uuid = None
    try:
        with open(path, "r", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                u = d.get("uuid")
                if not u:
                    continue
                parent[u] = d.get("parentUuid")
                last_uuid = u
    except OSError:
        return set()
    live = set()
    cur = last_uuid
    while cur is not None and cur in parent and cur not in live:
        live.add(cur)
        cur = parent[cur]
    return live


def classify_match(path, matched_uuid, _live_cache=None):
    """Is `matched_uuid` on the branch Claude will resume to, or stranded on an
    abandoned fork? Returns "live-path" | "stale-branch".

    "stale-branch" means: your search hit a message that resume will NOT show —
    you'd land on a different (newer) branch of the same session. Unknown ids
    and chainless files fall back to "live-path" (don't cry wolf)."""
    if matched_uuid is None:
        return "live-path"
    live = _live_cache if _live_cache is not None else _claude_live_path_uuids(path)
    if not live:
        return "live-path"
    return "live-path" if matched_uuid in live else "stale-branch"


def _claude_match_uuid(path, query):
    """uuid of the first transcript message whose text contains `query`
    (case-insensitive). Lets the resume path know which branch the hit is on."""
    ql = query.lower()
    try:
        with open(path, "r", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                if not d.get("uuid"):
                    continue
                if ql in _claude_extract_text(d).lower():
                    return d["uuid"]
    except OSError:
        pass
    return None


def _claude_extract_text(entry):
    parts = []
    msg = entry.get("message")
    if isinstance(msg, dict):
        c = msg.get("content")
        if isinstance(c, str):
            parts.append(c)
        elif isinstance(c, list):
            for b in c:
                if not isinstance(b, dict):
                    continue
                t = b.get("type")
                if t == "text" and isinstance(b.get("text"), str):
                    parts.append(b["text"])
                elif t == "tool_result":
                    rc = b.get("content")
                    if isinstance(rc, str):
                        parts.append(rc)
                    elif isinstance(rc, list):
                        for rb in rc:
                            if isinstance(rb, dict) and isinstance(rb.get("text"), str):
                                parts.append(rb["text"])
    if isinstance(entry.get("summary"), str):
        parts.append(entry["summary"])
    return "\n".join(parts)


# Blocks the Claude Code harness embeds INSIDE user messages that aren't the
# user's own words: system reminders, and the output of `!`-prefix / slash
# commands (the typed command itself stays searchable).
_CLAUDE_INJECTED_RE = re.compile(
    r"<(system-reminder|bash-stdout|bash-stderr|local-command-stdout|"
    r"local-command-stderr)>.*?</\1>", re.DOTALL)


def _claude_extract_user_text(entry):
    """Only text the user actually typed: user-type entries, text blocks only
    (tool_result blocks ride on user entries but are tool output, not the
    user's words). isMeta entries are harness-injected, not the user."""
    if entry.get("type") != "user" or entry.get("isMeta"):
        return ""
    msg = entry.get("message")
    if not isinstance(msg, dict):
        return ""
    c = msg.get("content")
    parts = []
    if isinstance(c, str):
        parts.append(c)
    elif isinstance(c, list):
        for b in c:
            if (isinstance(b, dict) and b.get("type") == "text"
                    and isinstance(b.get("text"), str)):
                parts.append(b["text"])
    return _CLAUDE_INJECTED_RE.sub("", "\n".join(parts))


def claude_resumable(path):
    parent_dir = os.path.dirname(path)
    if os.path.basename(parent_dir) == "subagents":
        return os.path.basename(os.path.dirname(parent_dir)), True
    base = os.path.basename(path)
    return (base[:-6] if base.endswith(".jsonl") else base), False


def _claude_read_cwd(path):
    try:
        with open(path, "r", errors="replace") as fh:
            for line in fh:
                try:
                    e = json.loads(line)
                except Exception:
                    continue
                if isinstance(e.get("cwd"), str):
                    return e["cwd"]
    except Exception:
        return None
    return None


def claude_find(query, user_only=False):
    if not claude_available():
        return []
    extract = _claude_extract_user_text if user_only else _claude_extract_text
    roots = claude_roots()
    if not roots:
        return []
    # Empty query: no filter, just list what's there (used for the default
    # "recent conversations" view before the user types anything).
    listing = not query
    if listing:
        paths = []
        for root in roots:
            paths.extend(glob.glob(os.path.join(root, "**", "*.jsonl"),
                                    recursive=True))
    else:
        try:
            out = subprocess.run(
                ["rg", "-l", "--no-ignore", "--hidden",
                 "--ignore-case", "-e", _sep_pattern(query), *roots],
                capture_output=True, text=True, timeout=20)
            paths = [p for p in out.stdout.splitlines() if p.endswith(".jsonl")]
        except Exception:
            return []
    paths.sort(key=lambda p: os.path.getmtime(p) if os.path.exists(p) else 0,
               reverse=True)
    paths = paths[:MAX_FILES]
    ql = query.lower()
    results = []
    for path in paths:
        cwd = ts = snippet = raw_hit = match_uuid = None
        try:
            with open(path, "r", errors="replace") as fh:
                for line in fh:
                    line = line.rstrip("\n")
                    if not line:
                        continue
                    if not listing and raw_hit is None and ql in line.lower():
                        raw_hit = line
                    try:
                        entry = json.loads(line)
                    except Exception:
                        continue
                    if cwd is None and isinstance(entry.get("cwd"), str):
                        cwd = entry["cwd"]
                    if snippet is None:
                        txt = extract(entry)
                        if txt:
                            s = first_text(txt) if listing else first_text_match(txt, query)
                            if s:
                                snippet = s
                                ts = entry.get("timestamp") or ts
                                match_uuid = entry.get("uuid")  # where the hit is
                    if snippet and cwd:
                        break
        except Exception:
            continue
        # raw fallback matches anywhere in the line (incl. AI/tool content),
        # so it would defeat the user-only filter — skip it in that mode.
        if snippet is None and raw_hit is not None and not user_only:
            snippet = raw_snippet(raw_hit, query)
            try:
                match_uuid = json.loads(raw_hit).get("uuid")
            except Exception:
                pass
        if snippet is None:
            continue
        if ts is None:
            ts = os.path.getmtime(path) if os.path.exists(path) else None
        sid, is_sub = claude_resumable(path)
        results.append({
            "source": "claude", "sid": sid, "is_sub": is_sub,
            "cwd": cwd, "ts": ts, "snippet": snippet, "row_path": path,
            "match_uuid": match_uuid,
        })
    return results


def claude_resume_argv(row):
    sid = row["sid"]
    cwd = row.get("cwd")
    path = row.get("row_path") or ""
    if row.get("is_sub"):
        proj_dir = os.path.dirname(os.path.dirname(os.path.dirname(path)))
        parent_file = os.path.join(proj_dir, sid + ".jsonl")
        pcwd = _claude_read_cwd(parent_file)
        if pcwd:
            cwd = pcwd
    # Point `claude` at the account that owns this transcript, otherwise a
    # resume from a non-active account fails with "conversation ID not found".
    cfg = _claude_config_dir_for_path(path)
    if cfg:
        os.environ["CLAUDE_CONFIG_DIR"] = cfg
    return cwd, ["claude", "--resume", sid]


# =====================
# HERMES adapter
# =====================
def hermes_available():
    return os.path.isdir(HERMES_ROOT) and (
        os.path.isdir(os.path.join(HERMES_ROOT, "sessions")) or
        os.path.isdir(os.path.join(HERMES_ROOT, "profiles")))


def hermes_sid_from_path(path):
    base = os.path.basename(path)
    for ext in (".jsonl", ".json"):
        if base.endswith(ext):
            base = base[:-len(ext)]
            break
    if base.startswith("session_"):
        base = base[len("session_"):]
    return base


def _hermes_text_from_json(d, user_only=False):
    parts = []
    for m in d.get("messages", []) or []:
        if not isinstance(m, dict):
            continue
        if user_only and m.get("role") != "user":
            continue
        c = m.get("content")
        if isinstance(c, str):
            parts.append(c)
        elif isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and isinstance(b.get("text"), str):
                    parts.append(b["text"])
                elif isinstance(b, str):
                    parts.append(b)
    if not user_only and isinstance(d.get("title"), str):
        parts.append(d["title"])
    return "\n".join(parts)


def hermes_find(query, user_only=False):
    if not hermes_available():
        return []
    listing = not query
    if listing:
        paths = (glob.glob(os.path.join(HERMES_ROOT, "**", "*.json"), recursive=True) +
                 glob.glob(os.path.join(HERMES_ROOT, "**", "*.jsonl"), recursive=True))
    else:
        try:
            out = subprocess.run(
                ["rg", "-l", "--no-ignore", "--hidden",
                 "--ignore-case", "--glob", "*.json", "--glob", "*.jsonl",
                 "-e", _sep_pattern(query), HERMES_ROOT],
                capture_output=True, text=True, timeout=20)
            paths = [p for p in out.stdout.splitlines()
                     if p.endswith((".json", ".jsonl"))]
        except Exception:
            return []
    paths = [p for p in paths if "/sessions/" in p or p.endswith("/sessions.json")]
    paths.sort(key=lambda p: os.path.getmtime(p) if os.path.exists(p) else 0,
               reverse=True)
    paths = paths[:MAX_FILES]
    results = []
    for path in paths:
        sid = hermes_sid_from_path(path)
        ts = snippet = None
        try:
            if path.endswith(".jsonl"):
                texts = []
                with open(path, "r", errors="replace") as fh:
                    for line in fh:
                        try:
                            e = json.loads(line)
                        except Exception:
                            continue
                        if ts is None and e.get("timestamp"):
                            ts = e["timestamp"]
                        if user_only and e.get("role") != "user":
                            continue
                        c = e.get("content")
                        if isinstance(c, str):
                            texts.append(c)
                        elif isinstance(c, list):
                            for b in c:
                                if isinstance(b, dict) and isinstance(b.get("text"), str):
                                    texts.append(b["text"])
                joined = "\n".join(texts)
                snippet = first_text(joined) if listing else first_text_match(joined, query)
            else:
                with open(path, "r", errors="replace") as fh:
                    try:
                        d = json.load(fh)
                    except Exception:
                        d = None
                if isinstance(d, dict):
                    if d.get("session_id"):
                        sid = d["session_id"]
                    ts = d.get("last_updated") or d.get("session_start")
                    text = _hermes_text_from_json(d, user_only)
                    snippet = first_text(text) if listing else first_text_match(text, query)
        except Exception:
            continue
        if snippet is None and not user_only and not listing:
            try:
                with open(path, "r", errors="replace") as fh:
                    snippet = raw_snippet(fh.read(), query)
            except Exception:
                snippet = None
        if snippet is None:
            continue
        if ts is None:
            ts = os.path.getmtime(path) if os.path.exists(path) else None
        cwd_hint = None
        m = re.search(r"/profiles/([^/]+)/", path)
        if m:
            cwd_hint = "profile:" + m.group(1)
        results.append({
            "source": "hermes", "sid": sid, "is_sub": False,
            "cwd": cwd_hint, "ts": ts, "snippet": snippet, "row_path": path,
        })
    return results


def hermes_resume_argv(row):
    return None, ["hermes", "--resume", row["sid"]]


# =====================
# OPENCODE adapter
# =====================
def opencode_available():
    return os.path.isfile(OPENCODE_DB)


def _opencode_text(data_str):
    try:
        d = json.loads(data_str)
    except Exception:
        return data_str
    if not isinstance(d, dict):
        return data_str
    parts = []
    t = d.get("type")
    if t == "text" and isinstance(d.get("text"), str):
        parts.append(d["text"])
    elif t == "tool":
        for k in ("input", "output", "content"):
            v = d.get(k)
            if isinstance(v, str):
                parts.append(v)
            elif isinstance(v, dict):
                parts.append(json.dumps(v))
    else:
        c = d.get("content")
        if isinstance(c, str):
            parts.append(c)
        elif isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and isinstance(b.get("text"), str):
                    parts.append(b["text"])
        for k in ("text", "title", "summary"):
            v = d.get(k)
            if isinstance(v, str):
                parts.append(v)
    return "\n".join(parts) or data_str


def opencode_find(query, user_only=False):
    if not opencode_available():
        return []
    join = role = ""
    if user_only:
        # role lives on the message row's JSON metadata, not the part
        join = "JOIN message m ON p.message_id = m.id"
        role = "AND json_extract(m.data, '$.role') = 'user'"
    rows_out = []
    conn = None
    try:
        conn = sqlite3.connect("file:%s?mode=ro" % OPENCODE_DB, uri=True,
                               timeout=5)
        conn.row_factory = sqlite3.Row
        cur = conn.cursor()
        cur.execute(
            f"""
            SELECT p.session_id AS sid, p.data AS pdata, p.time_created AS pts,
                   s.directory AS dir, s.parent_id AS parent_id,
                   s.title AS title, s.agent AS agent,
                   s.time_updated AS sts
            FROM part p
            JOIN session s ON p.session_id = s.id
            {join}
            WHERE lower(p.data) LIKE lower(?) {role}
            ORDER BY p.time_created DESC
            LIMIT 400
            """, ("%" + query + "%",))
        rows_out = cur.fetchall()
    except Exception:
        rows_out = []
    finally:
        try:
            if conn is not None:
                conn.close()
        except Exception:
            pass
    seen = set()
    results = []
    listing = not query
    for r in rows_out:
        sid = r["sid"]
        if sid in seen:
            continue
        if listing:
            snippet = first_text(r["title"]) or first_text(_opencode_text(r["pdata"]))
        else:
            snippet = first_text_match(_opencode_text(r["pdata"]), query)
            if snippet is None:
                snippet = raw_snippet(r["pdata"], query)
        if snippet is None:
            continue
        seen.add(sid)
        is_sub = bool(r["parent_id"])
        resume_sid = r["parent_id"] if is_sub else sid
        ts = r["sts"] or r["pts"]
        results.append({
            "source": "opencode", "sid": resume_sid,
            "display_id": sid, "is_sub": is_sub,
            "cwd": r["dir"], "ts": ts, "snippet": snippet,
            "row_path": "opencode:" + sid,
        })
    return results[:MAX_FILES]


def opencode_resume_argv(row):
    return row.get("cwd"), ["opencode", "--session", row["sid"]]


# =====================
# Dispatch
# =====================
SOURCES = {
    "claude":   {"find": claude_find,   "resume": claude_resume_argv,
                 "available": claude_available},
    "hermes":   {"find": hermes_find,   "resume": hermes_resume_argv,
                 "available": hermes_available},
    "opencode": {"find": opencode_find, "resume": opencode_resume_argv,
                 "available": opencode_available},
}


def _encode_field1(row):
    # source|sid|is_sub|match_uuid|row_path  (row_path is last; any chars.
    # match_uuid is the message the search hit — empty if unknown.)
    return "{}|{}|{}|{}|{}".format(
        row["source"], row["sid"], 1 if row.get("is_sub") else 0,
        row.get("match_uuid") or "", row.get("row_path") or "")


def _decode_field1(field1):
    parts = field1.split("|", 4)
    if len(parts) < 5:
        return {"source": "claude", "sid": "", "is_sub": False,
                "match_uuid": "", "row_path": field1}
    source, sid, is_sub_s, match_uuid, row_path = parts
    return {"source": source, "sid": sid, "is_sub": (is_sub_s == "1"),
            "match_uuid": match_uuid or None, "row_path": row_path}


def _env_user_only():
    """fzf exports FZF_PROMPT to reload/preview subprocesses; the prompt is
    how the in-UI Ctrl-U toggle communicates the mode to us."""
    return os.environ.get("FZF_PROMPT") == PROMPT_USER


def backend(query, enabled=None, user_only=False):
    stripped = query.strip()
    if stripped:
        if len(stripped) < 2:
            return
    else:
        # No text typed yet: fall through to each source's listing mode
        # (empty query), which shows recent conversations sorted by last
        # updated instead of nothing.
        query = ""
    all_rows = []
    for name, src in SOURCES.items():
        if enabled and name not in enabled:
            continue
        if not src["available"]():
            continue
        try:
            all_rows.extend(src["find"](query, user_only))
        except Exception:
            continue
    all_rows.sort(key=lambda r: ts_key(r.get("ts")), reverse=True)
    # When ccfind runs from inside a Claude session, that session inherits the
    # query in its own transcript (you typed it) and, being the newest, would
    # rank first — resuming it just drops you back where you are. Hide it.
    own_sid = os.environ.get("CLAUDE_CODE_SESSION_ID")
    seen = set()
    emitted = 0
    for r in all_rows:
        if own_sid and r["source"] == "claude" and r["sid"] == own_sid:
            continue
        key = (r["source"], r["sid"])
        if key in seen:
            continue
        seen.add(key)
        tag = " ↳ sub-agent" if r.get("is_sub") else ""
        badge = BADGES.get(r["source"], "[?]")
        cwd_disp = abbrev(r["cwd"]) if r.get("cwd") else "?"
        left = (badge + " " + highlight(r["snippet"], query) + "  "
                + DIM + "· " + cwd_disp + tag + RESET)
        left = left.replace("\t", " ").replace("\n", " ")
        disp = align_right(left, fmt_ts(r.get("ts")))
        field1 = _encode_field1(r)
        cwd_f = (r.get("cwd") or "").replace("\t", " ")
        ts_f = str(r.get("ts") or "").replace("\t", " ")
        sys.stdout.write(f"{field1}\t{cwd_f}\t{ts_f}\t{disp}\n")
        emitted += 1
        if emitted >= MAX_RESULTS:
            break


def preview(field1, query, user_only=False):
    info = _decode_field1(field1)
    source = info["source"]
    sid = info["sid"]
    is_sub = info["is_sub"]
    row_path = info["row_path"]
    badge = BADGES.get(source, source)
    print(BOLD + "Source   " + RESET + badge + " " + source)
    print(BOLD + "Session  " + RESET + CYAN + sid + RESET +
          (DIM + "  (resumable parent)" + RESET if is_sub else ""))
    if source == "claude" and is_sub:
        print(BOLD + "Match in " + RESET + DIM + os.path.basename(row_path)
              + " (sub-agent)" + RESET)
    elif source == "hermes":
        m = re.search(r"/profiles/([^/]+)/", row_path)
        if m:
            print(BOLD + "Profile  " + RESET + m.group(1))
    elif source == "opencode" and is_sub:
        print(BOLD + "Sub      " + RESET + DIM + row_path + RESET)
    if source in SOURCES:
        try:
            rows = SOURCES[source]["find"](query, user_only)
        except Exception:
            rows = []
        match = next((r for r in rows
                      if r.get("row_path") == row_path), None)
        if not match:
            match = next((r for r in rows if r["sid"] == sid), None)
        if match:
            print(BOLD + "Dir      " + RESET + abbrev(match.get("cwd") or "?"))
            if source == "claude" and len(claude_roots()) > 1:
                cfg = _claude_config_dir_for_path(match.get("row_path") or "")
                if cfg:
                    print(BOLD + "Account  " + RESET + os.path.basename(cfg))
            ts = match.get("ts")
            if ts:
                pretty = fmt_ts(ts)
                print(BOLD + "Match at " + RESET + YELLOW + (pretty or str(ts)[:24]) + RESET +
                      (DIM + "  " + str(ts)[:24] + RESET if pretty and str(ts)[:16] not in pretty else ""))
            print()
            print(highlight(match.get("snippet", ""), query))
            print()
            stale = (source == "claude" and match.get("match_uuid")
                     and classify_match(match["row_path"], match["match_uuid"])
                     == "stale-branch")
            if stale:
                print(YELLOW + "⑂ this match is on an older branch of the session "
                      "(it diverged — e.g. an edited/re-sent message)." + RESET)
                print(DIM + "  Enter forks at this match so you land here, not on "
                      "the session's newer branch." + RESET)
            else:
                print(DIM + "tip: pressing Enter resumes the session at its LATEST state." + RESET)
                print(DIM + "     if the session covered multiple topics, scroll up to the match time above." + RESET)


def branch_claude_session(parent_path, parent_sid, checkpoint_uuid):
    """Fork a Claude Code session at checkpoint_uuid (a user-message uuid).
    Copies every entry from the parent up to (but NOT including) the next user
    message after the checkpoint — i.e. includes the user message + its full
    assistant response. Rewrites sessionId; tags every copied entry with
    `forkedFrom: {sessionId, messageUuid}` (matching Claude Code's own /btw).
    Returns (new_sid, new_path)."""
    entries = []
    with open(parent_path, "r", errors="replace") as fh:
        for line in fh:
            line = line.rstrip("\n")
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except Exception:
                continue
    cp_idx = next((i for i, e in enumerate(entries)
                   if e.get("uuid") == checkpoint_uuid), None)
    if cp_idx is None:
        raise ValueError(f"checkpoint uuid {checkpoint_uuid} not found in {parent_path}")
    end_idx = len(entries)
    for j in range(cp_idx + 1, len(entries)):
        if entries[j].get("type") == "user":
            end_idx = j
            break
    copied = [dict(e) for e in entries[:end_idx]]
    new_sid = str(_uuid_mod.uuid4())
    forked = {"sessionId": parent_sid, "messageUuid": checkpoint_uuid}
    for e in copied:
        e["sessionId"] = new_sid
        e["forkedFrom"] = forked
    new_path = _branch_target_path(parent_path, copied, new_sid)
    os.makedirs(os.path.dirname(new_path), exist_ok=True)
    with open(new_path, "w") as fh:
        for e in copied:
            fh.write(json.dumps(e, ensure_ascii=False))
            fh.write("\n")
    return new_sid, new_path


def _claude_slug_for_cwd(cwd):
    """Mirror Claude's project-folder rule: every non-alphanumeric char → `-`.
    (Verified against real transcripts; see adapters/claude.slug_for_cwd.)"""
    return re.sub(r"[^a-zA-Z0-9]", "-", cwd)


def _branch_target_path(parent_path, copied_entries, new_sid):
    """Where to write a branched transcript so `claude --resume` can find it.

    Must NOT just sit next to the parent: an old parent may live in a stale slug
    folder (e.g. `.nosync` kept as a dot) that today's Claude won't derive from
    the cwd. Instead write into `<config-dir>/projects/<slug(cwd)>/`, using the
    parent's owning config dir and Claude's current slug rule. Falls back to the
    parent's folder if cwd/config can't be determined."""
    cwd = next((e.get("cwd") for e in copied_entries
                if isinstance(e.get("cwd"), str) and e.get("cwd")), None)
    cfg = _claude_config_dir_for_path(parent_path)
    if cwd and cfg:
        return os.path.join(cfg, "projects", _claude_slug_for_cwd(cwd),
                            new_sid + ".jsonl")
    return os.path.join(os.path.dirname(parent_path), new_sid + ".jsonl")


def branch_flow_claude(parent_path, parent_sid):
    """Interactive branch picker. Lists user messages in the session via fzf;
    user picks one; creates the fork. Returns (new_sid, new_path) or None."""
    entries = []
    with open(parent_path, "r", errors="replace") as fh:
        for line in fh:
            try:
                entries.append(json.loads(line))
            except Exception:
                continue
    candidates = []
    for e in entries:
        if e.get("type") != "user":
            continue
        msg = e.get("message")
        c = msg.get("content") if isinstance(msg, dict) else None
        text = ""
        if isinstance(c, str):
            text = c
        elif isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and isinstance(b.get("text"), str):
                    text = b["text"]
                    break
        text = re.sub(r"\s+", " ", text or "").strip()
        if not text:
            continue
        uid = e.get("uuid", "")
        ts = e.get("timestamp", "")
        if uid:
            candidates.append((uid, ts, text[:240]))
    if not candidates:
        sys.exit("ccfind: no branchable user messages found in this session")
    lines = []
    for uid, ts, text in candidates:
        when = fmt_ts(ts) if ts else "             "
        # field 1 = uuid (hidden), field 2 = display (timestamp + preview)
        lines.append(f"{uid}\t{DIM}{when}{RESET} {text}")
    fzf_input = "\n".join(lines)
    try:
        res = subprocess.run(
            ["fzf", "--ansi", "--delimiter", "\t", "--with-nth", "2",
             "--layout", "reverse", "--height", "70%",
             "--prompt", "branch from> ",
             "--header", "pick a user message to branch from  "
                         "(↑↓ move · enter pick · esc cancel)"],
            input=fzf_input, stdout=subprocess.PIPE, text=True)
    except FileNotFoundError:
        sys.exit("ccfind: fzf not found")
    line = (res.stdout or "").strip()
    if res.returncode != 0 or not line:
        return None
    chosen_uid = line.split("\t", 1)[0]
    return branch_claude_session(parent_path, parent_sid, chosen_uid)


def _fzf_version():
    try:
        out = subprocess.run(["fzf", "--version"], capture_output=True,
                             text=True, timeout=5).stdout or ""
        m = re.match(r"(\d+)\.(\d+)", out.strip())
        if m:
            return int(m.group(1)), int(m.group(2))
    except Exception:
        pass
    return (0, 0)


def launch(enabled=None, user_only=False):
    self = os.path.abspath(__file__)
    me = shlex.quote(self)
    src_arg = ""
    if enabled:
        src_arg = " --source " + ",".join(sorted(enabled))
    backend_cmd = f"{me}{src_arg} --backend {{q}}"
    preview_cmd = f"{me} --preview {{1}} {{q}}"
    detected = [n for n, s in SOURCES.items() if s["available"]()]
    if enabled:
        detected = [n for n in detected if n in enabled]
    header = ("agents: " + (", ".join(detected) if detected else "none detected")
              + "\nEnter resume  ·  " + YELLOW + "Ctrl-B branch" + RESET
              + "  ·  " + YELLOW + "Ctrl-X port→claude" + RESET
              + "  ·  " + YELLOW + "Ctrl-U user-only" + RESET + "  ·  Esc quit")
    # Ctrl-U flips the prompt (which IS the mode — backend reads FZF_PROMPT
    # from its env) and reloads. `\{q}` keeps the placeholder literal through
    # the transform so fzf expands it safely at reload time.
    backend_cmd_lit = f"{me}{src_arg} --backend \\{{q}}"
    toggle = ('transform:case "$FZF_PROMPT" in '
              f'"{PROMPT_USER}") echo "change-prompt({PROMPT_ALL})'
              f'+reload({backend_cmd_lit})";; '
              f'*) echo "change-prompt({PROMPT_USER})'
              f'+reload({backend_cmd_lit})";; esac')
    cmd = [
        "fzf",
        "--ansi", "--disabled",
        "--delimiter", "\t",
        "--with-nth", "4",
        "--layout", "reverse",
        "--info", "inline",
        "--prompt", PROMPT_USER if user_only else PROMPT_ALL,
        "--header", header,
        "--expect", "ctrl-b,ctrl-x",
        "--bind", f"start:reload({backend_cmd})",
        "--bind", f"change:reload({backend_cmd})",
        "--bind", f"ctrl-u:{toggle}",
        "--preview", preview_cmd,
        "--preview-window", "down,45%,wrap,border-top",
    ]
    if _fzf_version() >= (0, 62):
        cmd += ["--ghost",
                "showing recent sessions — type a phrase to search (2+ chars) — "
                "Ctrl-U to match only what you typed"]
    try:
        res = subprocess.run(cmd, stdout=subprocess.PIPE, text=True)
    except FileNotFoundError:
        sys.exit("ccfind: fzf not found (brew install fzf, "
                 "or nix run github:coolcorexix/claude-grep)")
    out = res.stdout or ""
    # With --expect, fzf prints the pressed key on the first line (empty=Enter),
    # then the selection on the next line.
    parts = out.split("\n", 1)
    pressed_key = parts[0].strip()
    selection_line = (parts[1].strip() if len(parts) > 1 else "")
    if res.returncode != 0 or not selection_line:
        return
    fields = selection_line.split("\t")
    if len(fields) < 2:
        return
    info = _decode_field1(fields[0])
    fallback_cwd = fields[1] or None
    source = info["source"]
    if source not in SOURCES:
        sys.exit(f"ccfind: unknown source {source!r}")

    # Ctrl-X → port a session into the other agent. Claude rows port to
    # OpenCode; OpenCode/Hermes rows port to Claude Code. Reads the source
    # via ccfind_core's canonical IR, writes a fresh resumable target
    # transcript, then resumes it.
    if pressed_key == "ctrl-x":
        try:
            from ccfind_core import adapters as _cc_adapters
        except ImportError as e:
            sys.exit(f"ccfind: ctrl-x needs the ccfind_core package "
                     f"(import failed: {e}). Reinstall ccfind.")
        sid = info["sid"]

        # Determine target direction
        if source == "claude":
            target = "opencode"
            if not opencode_available():
                sys.exit("ccfind: OpenCode DB not found; cannot port to OpenCode")
        elif source in ("opencode", "hermes"):
            target = "claude"
        else:
            sys.exit(f"ccfind: ctrl-x not supported for {source!r}")

        if not _cc_adapters.can(source, "read"):
            sys.exit(f"ccfind: ccfind_core has no reader for {source!r}")
        if not _cc_adapters.can(target, "write"):
            sys.exit(f"ccfind: ccfind_core has no writer for {target!r}")

        sys.stderr.write(
            f"ccfind: porting {source} session {sid} → {target.title()} Code…\n")

        read_kwargs = {}
        if source == "hermes" and info.get("row_path"):
            read_kwargs["path"] = info["row_path"]
        if source == "claude" and info.get("row_path"):
            read_kwargs["path"] = info["row_path"]

        try:
            conv = _cc_adapters.read(source, sid, **read_kwargs)
        except Exception as e:
            sys.exit(f"ccfind: failed to read {source} session: {e}")

        conv.metadata.setdefault("forkedFrom", {
            "source_agent": source,
            "source_session_id": sid,
        })

        port_cwd = conv.cwd or fallback_cwd
        if port_cwd and (port_cwd.startswith("profile:") or not os.path.isdir(port_cwd)):
            port_cwd = os.getcwd()
        if not port_cwd:
            port_cwd = os.getcwd()

        try:
            result = _cc_adapters.write(target, conv, cwd=port_cwd)
        except Exception as e:
            sys.exit(f"ccfind: failed to write {target} transcript: {e}")
        new_sid = result["session_id"]
        out_cwd = result["cwd"]
        sys.stderr.write(
            f"ccfind: created {target} session {new_sid}\n"
            f"        from {source}://{sid}\n"
            f"        at {result['path']}\n"
            f"        → resuming in {out_cwd}…\n"
        )

        if target == "claude":
            cfg = _claude_config_dir_for_path(result["path"])
            if cfg:
                os.environ["CLAUDE_CONFIG_DIR"] = cfg
            if out_cwd and os.path.isdir(out_cwd):
                os.chdir(out_cwd)
            try:
                os.execvp("claude", ["claude", "--resume", new_sid])
            except FileNotFoundError:
                sys.exit("ccfind: command not found: claude")
        else:
            if out_cwd and os.path.isdir(out_cwd):
                os.chdir(out_cwd)
            try:
                os.execvp("opencode", ["opencode", "--session", new_sid])
            except FileNotFoundError:
                sys.exit("ccfind: command not found: opencode")
        return

    # Ctrl-B → branch (fork the session from a chosen user message)
    if pressed_key == "ctrl-b":
        if source != "claude":
            sys.exit(f"ccfind: branching not yet supported for {source!r} "
                     "(claude only in this MVP)")
        parent_path = info["row_path"]
        parent_sid = info["sid"]
        if info["is_sub"]:
            proj_dir = os.path.dirname(os.path.dirname(os.path.dirname(parent_path)))
            parent_path = os.path.join(proj_dir, parent_sid + ".jsonl")
        try:
            result = branch_flow_claude(parent_path, parent_sid)
        except Exception as e:
            sys.exit(f"ccfind: branch failed: {e}")
        if not result:
            return
        new_sid, new_path = result
        sys.stderr.write(
            f"ccfind: created branch {new_sid} from {parent_sid} → resuming…\n")
        # The branch is written beside its parent, so resume under the parent's
        # account (config dir), not whichever one happens to be active.
        cfg = _claude_config_dir_for_path(new_path)
        if cfg:
            os.environ["CLAUDE_CONFIG_DIR"] = cfg
        cwd = _claude_read_cwd(parent_path) or fallback_cwd
        if cwd and os.path.isdir(cwd):
            os.chdir(cwd)
        try:
            os.execvp("claude", ["claude", "--resume", new_sid])
        except FileNotFoundError:
            sys.exit("ccfind: command not found: claude")
        return

    # Normal Enter → resume.
    # If the matched message lives on an ABANDONED branch of a diverged session
    # (edit/resend/two-terminals), `claude --resume <sid>` would open the
    # session's newest tip instead — i.e. a different conversation than the one
    # you searched for. Detect that and fork at the matched message so you land
    # exactly where your hit was. Only applies to claude, non-sub-agent rows.
    if (source == "claude" and not info["is_sub"] and info.get("match_uuid")
            and classify_match(info["row_path"], info["match_uuid"]) == "stale-branch"):
        try:
            new_sid, new_path = branch_claude_session(
                info["row_path"], info["sid"], info["match_uuid"])
        except Exception as e:
            sys.stderr.write(f"ccfind: could not branch at match ({e}); "
                             "resuming session's latest state instead\n")
        else:
            sys.stderr.write(
                f"ccfind: your match was on an older branch of {info['sid'][:8]} "
                f"(resuming it directly would open a different, newer thread).\n"
                f"        forked at the match → {new_sid[:8]}; resuming that.\n")
            cfg = _claude_config_dir_for_path(new_path)
            if cfg:
                os.environ["CLAUDE_CONFIG_DIR"] = cfg
            cwd = _claude_read_cwd(info["row_path"]) or fallback_cwd
            if cwd and os.path.isdir(cwd):
                os.chdir(cwd)
            try:
                os.execvp("claude", ["claude", "--resume", new_sid])
            except FileNotFoundError:
                sys.exit("ccfind: command not found: claude")
            return

    row = {
        "source": source, "sid": info["sid"],
        "is_sub": info["is_sub"], "row_path": info["row_path"],
        "cwd": fallback_cwd,
    }
    cwd, argv = SOURCES[source]["resume"](row)
    sys.stderr.write(f"ccfind: resuming {source} session {info['sid'][:8]}…\n")
    if cwd and os.path.isdir(cwd):
        os.chdir(cwd)
    elif cwd:
        sys.stderr.write(
            f"ccfind: original dir missing ({cwd}); resuming from here\n")
    try:
        os.execvp(argv[0], argv)
    except FileNotFoundError:
        sys.exit(f"ccfind: command not found: {argv[0]}")


def _parse_sources(arg):
    names = [s.strip().lower() for s in arg.split(",") if s.strip()]
    bad = [n for n in names if n not in SOURCES]
    if bad:
        sys.exit("ccfind: unknown source(s): " + ", ".join(bad)
                 + " (known: " + ", ".join(SOURCES) + ")")
    return set(names) if names else None


def main():
    args = sys.argv[1:]
    enabled = None
    user_only = False
    i = 0
    rest = []
    while i < len(args):
        a = args[i]
        if a == "--source" and i + 1 < len(args):
            enabled = _parse_sources(args[i + 1])
            i += 2
        elif a.startswith("--source="):
            enabled = _parse_sources(a.split("=", 1)[1])
            i += 1
        elif a in ("--user-only", "-u"):
            user_only = True
            i += 1
        else:
            rest.append(a)
            i += 1
    args = rest

    if not args:
        launch(enabled, user_only)
    elif args[0] == "--backend":
        backend(args[1] if len(args) > 1 else "", enabled,
                user_only or _env_user_only())
    elif args[0] == "--preview":
        preview(args[1] if len(args) > 1 else "",
                args[2] if len(args) > 2 else "",
                user_only or _env_user_only())
    elif args[0] == "--sources":
        for n, s in SOURCES.items():
            ok = s["available"]()
            print(f"  {n}: {'AVAILABLE' if ok else 'not detected'}")
            if n == "claude" and ok:
                roots = claude_roots()
                if len(roots) > 1:
                    for r in roots:
                        acct = os.path.basename(os.path.dirname(r))
                        print(f"      account: {acct}  ({abbrev(r)})")
    else:
        sys.exit(__doc__)


